# PandemoniumProtocol ignore rules (gitignore-style).
# Self-exclusion + secrets + build artifacts + binaries. Edited freely; secrets
# and the .pandemonium/ data dir should always stay excluded.

# --- self-exclusion (the index must never index its own store) ---
.pandemonium/
.git/
.venv/
venv/
env/

# --- eval harness + diagnostic scaffolding (NOT user-navigable source) ---
# The eval harness imports gold.py from disk (sys.path), never from the index, so
# excluding evals/ is safe. evals/gold.py embeds the 15 query strings verbatim — indexing
# it makes the eval's own labels the top distractor for its own queries (self-contamination).
# Fixture corpora here are already indexed separately by their own eval modes (--cpp etc.).
evals/
# generated / vendored viz assets (minified JS/CSS, served from disk — not source to search)
pandemonium/_assets/
# agent/skill config + drivers (e.g. .claude/skills/.../driver.py — a `run` name collision)
.claude/
# throwaway root probe / diagnostic scripts
_diag_index.py
_probe_stem.py

# --- generated / build / vendor ---
node_modules/
bin/
obj/
dist/
build/
target/
out/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# --- IDE ---
.vs/
.idea/
.vscode/

# --- secrets (NEVER index) ---
.env
.env.*
*.pem
*.key
*.pfx
*.cer
*.p12
secrets/
credentials/

# --- binaries / archives / compiled ---
*.zip
*.rar
*.7z
*.tar
*.gz
*.dll
*.exe
*.so
*.dylib
*.pyc
*.pyd
*.bin
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.pdf
